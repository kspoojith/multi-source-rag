# Streamlit Secrets Configuration
# ================================
# Copy this file to: .streamlit/secrets.toml
# Add your actual API keys and deploy to Streamlit Community Cloud

# ─── Groq API (Required for Cloud Deployment) ────────────────────────────────
# Get your free API key from: https://console.groq.com
# Free tier: 14,400 requests/day (plenty for most apps!)
GROQ_API_KEY = "gsk_YOUR_API_KEY_HERE"

# ─── LLM Provider Selection ───────────────────────────────────────────────────
# Options: "groq" or "ollama"
# - Use "groq" for Streamlit Cloud deployment (recommended)
# - Use "ollama" only if running locally
LLM_PROVIDER = "groq"

# ─── Groq Model Selection (Optional) ──────────────────────────────────────────
# Available free models:
# - "llama-3.3-70b-versatile" (Best quality - recommended, default)
# - "llama-3.1-8b-instant" (Faster)
# - "qwen/qwen3-32b" (Good balance, 131K context)
# - "openai/gpt-oss-120b" (Largest, experimental)
GROQ_MODEL = "llama-3.3-70b-versatile"

# ─── Other Settings (Optional) ────────────────────────────────────────────────
# Temperature (0.0-2.0): Lower = more factual, Higher = more creative
GROQ_TEMPERATURE = "0.3"

# Maximum tokens to generate (response length)
GROQ_MAX_TOKENS = "1024"

# ─── Note ─────────────────────────────────────────────────────────────────────
# For local development, you can set these as environment variables instead:
# export GROQ_API_KEY="your-key"
# export LLM_PROVIDER="groq"
# 
# Streamlit Cloud will automatically load these from the Secrets UI
