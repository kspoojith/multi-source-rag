# Environment Variables Configuration
# ====================================
# Copy this file to: .env
# Add your actual values and restart backend

# ─── LLM Provider Selection ───────────────────────────────────────────────────
# Options: "ollama" (local) or "groq" (cloud API)
# - Use "ollama" for local deployment (default)
# - Use "groq" for cloud deployment or faster local testing
LLM_PROVIDER=groq

# ─── Groq API Configuration (Cloud LLM) ───────────────────────────────────────
# Get free API key from: https://console.groq.com (14,400 requests/day free!)
GROQ_API_KEY=your_groq_api_key_here
# Model selection (optional - defaults shown)
# Options: llama-3.3-70b-versatile (best), llama-3.1-8b-instant (faster), qwen/qwen3-32b, openai/gpt-oss-120b
GROQ_MODEL=llama-3.3-70b-versatile

# Temperature: 0.0 (factual) to 2.0 (creative)
GROQ_TEMPERATURE=0.3

# Max response length in tokens
GROQ_MAX_TOKENS=1024

# ─── Ollama Configuration (Local LLM) ─────────────────────────────────────────
# Base URL for Ollama server (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Model name to use (default: phi3:mini)
# Options: phi3:mini (fast), mistral (better quality), llama3, gemma:7b
OLLAMA_MODEL=phi3:mini
