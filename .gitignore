# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# ─── Virtual Environment ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Environment Variables ────────────────────────────────────────────────────
.env

# ─── Streamlit Secrets (NEVER commit these!) ──────────────────────────────────
.streamlit/secrets.toml

# ─── Data (generated at runtime) ─────────────────────────────────────────────
