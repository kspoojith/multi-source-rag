data/index/
data/processed/
data/benchmark_results.json

# ─── Model Cache (downloaded on first run) ────────────────────────────────────
# Sentence-transformer models are cached in ~/.cache/ not here,
# but just in case:
models/
*.bin
*.safetensors

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── OS Generated ────────────────────────────────────────────────────────────
.DS_Store
Desktop.ini
ehthumbs.db
